# ─── Base de Datos ───
DATABASE_URL="postgresql://user:pass@host:5432/db"

# ─── JWT ───
JWT_SECRET="your-jwt-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── Stripe ───
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Wompi (Colombia - opcional) ───
WOMPI_PUBLIC_KEY="pub_test_..."
WOMPI_PRIVATE_KEY="priv_test_..."
WOMPI_EVENTS_KEY="events_test_..."
WOMPI_WEBHOOK_SECRET="wompi_whsec_..."

# ─── Email (Brevo / Sendinblue) ───
# Obtén tu API key en https://app.brevo.com > SMTP & API > API Keys
# Déjalo vacío o inválido para simular correos en consola
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM="noreply@tudominio.com"
EMAIL_FROM_NAME="Q10 Courses"

# ─── Servidor ───
PORT=3000
NODE_ENV=development
FRONTEND_URL="https://q10-courses.vercel.app"

# ─── Seguridad ───
SUPER_ADMIN_KEY="SuperAdmin2026!CambiaEsto"
